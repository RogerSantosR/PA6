{
  "info": {
    "name": "Plataforma de Cursos - API (ISIL PW II)",
    "description": "Colección de endpoints de la API REST. Configura la variable baseUrl. Al hacer login/register, el token se guarda automáticamente en la variable token.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:4000/api" },
    { "key": "token", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "courseId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "enrollmentId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/health" }
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register (student)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "if (pm.response.code === 201) { pm.collectionVariables.set('token', pm.response.json().token); }"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Nuevo Alumno\",\n  \"email\": \"nuevo@isil.edu.pe\",\n  \"password\": \"Passw0rd*\"\n}" }
          }
        },
        {
          "name": "Login (student)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "if (pm.response.code === 200) { pm.collectionVariables.set('token', pm.response.json().token); }"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"estudiante@isil.edu.pe\",\n  \"password\": \"Estudiante123*\"\n}" }
          }
        },
        {
          "name": "Login (admin)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "if (pm.response.code === 200) { pm.collectionVariables.set('adminToken', pm.response.json().token); }"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": { "mode": "raw", "raw": "{\n  \"email\": \"admin@isil.edu.pe\",\n  \"password\": \"Admin123*\"\n}" }
          }
        },
        {
          "name": "Me",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Categories",
      "item": [
        {
          "name": "List (public)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "if (pm.response.code === 200 && pm.response.json().length) { pm.collectionVariables.set('categoryId', pm.response.json()[0]._id); }"
            ] } }
          ],
          "request": { "method": "GET", "url": "{{baseUrl}}/categories" }
        },
        {
          "name": "Create (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/categories",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Marketing Digital\",\n  \"description\": \"SEO y ads\"\n}" }
          }
        },
        {
          "name": "Update (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/categories/{{categoryId}}",
            "body": { "mode": "raw", "raw": "{\n  \"name\": \"Desarrollo Web\",\n  \"description\": \"Actualizada\"\n}" }
          }
        },
        {
          "name": "Delete (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/categories/{{categoryId}}"
          }
        }
      ]
    },
    {
      "name": "Courses",
      "item": [
        {
          "name": "List (public, con busqueda)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "if (pm.response.code === 200 && pm.response.json().length) { pm.collectionVariables.set('courseId', pm.response.json()[0]._id); }"
            ] } }
          ],
          "request": { "method": "GET", "url": "{{baseUrl}}/courses?published=true&search=react" }
        },
        {
          "name": "Get by id (public)",
          "request": { "method": "GET", "url": "{{baseUrl}}/courses/{{courseId}}" }
        },
        {
          "name": "Create (admin)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "if (pm.response.code === 201) { pm.collectionVariables.set('courseId', pm.response.json()._id); }"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/courses",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Curso desde Postman\",\n  \"description\": \"Creado via API\",\n  \"category\": \"{{categoryId}}\",\n  \"instructor\": \"Docente\",\n  \"price\": 120,\n  \"capacity\": 30\n}" }
          }
        },
        {
          "name": "Update (admin)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/courses/{{courseId}}",
            "body": { "mode": "raw", "raw": "{\n  \"title\": \"Curso actualizado\",\n  \"description\": \"Nueva descripcion\",\n  \"category\": \"{{categoryId}}\",\n  \"instructor\": \"Docente\",\n  \"price\": 150,\n  \"capacity\": 25,\n  \"published\": true\n}" }
          }
        },
        {
          "name": "Delete (admin)",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/courses/{{courseId}}"
          }
        }
      ]
    },
    {
      "name": "Enrollments",
      "item": [
        {
          "name": "Enroll (student)",
          "event": [
            { "listen": "test", "script": { "exec": [
              "if (pm.response.code === 201) { pm.collectionVariables.set('enrollmentId', pm.response.json()._id); }"
            ] } }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{token}}" }
            ],
            "url": "{{baseUrl}}/enrollments",
            "body": { "mode": "raw", "raw": "{\n  \"courseId\": \"{{courseId}}\"\n}" }
          }
        },
        {
          "name": "My enrollments (student)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/enrollments/me"
          }
        },
        {
          "name": "Cancel (student/admin)",
          "request": {
            "method": "PATCH",
            "header": [{ "key": "Authorization", "value": "Bearer {{token}}" }],
            "url": "{{baseUrl}}/enrollments/{{enrollmentId}}/cancel"
          }
        },
        {
          "name": "List all (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/enrollments"
          }
        }
      ]
    },
    {
      "name": "Users",
      "item": [
        {
          "name": "List (admin)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/users"
          }
        }
      ]
    }
  ]
}
