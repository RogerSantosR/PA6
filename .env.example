# ==========================================================================
# .env.example — Plataforma de Gestión de Cursos e Inscripciones
# Copia este archivo a cada app y renómbralo a .env con tus valores reales.
# NUNCA subas el archivo .env real al repositorio.
# ==========================================================================

# ---------- backend/.env ----------
# PORT=4000
# MONGODB_URI=mongodb+srv://<usuario>:<password>@<cluster>.mongodb.net/plataforma_cursos
# JWT_SECRET=cambia-esto-por-una-cadena-larga-y-aleatoria
# JWT_EXPIRES_IN=1d
# CORS_ORIGINS=http://localhost:5173,http://localhost:4200,http://localhost:3000
# SEED_ADMIN_EMAIL=admin@isil.edu.pe
# SEED_ADMIN_PASSWORD=Admin123*
# SEED_STUDENT_EMAIL=estudiante@isil.edu.pe
# SEED_STUDENT_PASSWORD=Estudiante123*

# ---------- student-react/.env ----------
# VITE_API_URL=http://localhost:4000/api

# ---------- public-next/.env ----------
# NEXT_PUBLIC_API_URL=http://localhost:4000/api

# ---------- admin-angular (src/environments) ----------
# apiUrl se configura en src/environments/environment.ts
